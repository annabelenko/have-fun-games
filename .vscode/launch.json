  "version": "0.2.0",
  "configurations": [
    {
      "name": "Launch Backend",
      "request": "launch",
      "cwd": "${workspaceFolder}/backend",
      "args": ["run-script", "dev"],
      "runtimeExecutable": "npm",
      "skipFiles": ["<node_internals>/**"],
      "type": "node"
    },
    {
      "name": "Launch Frontend",
      "request": "launch",
      "cwd": "${workspaceFolder}/frontend",
      "args": ["run-script", "dev"],
      "runtimeExecutable": "npm",
      "skipFiles": ["<node_internals>/**"],
      "type": "node"
    }
  ]
}
